# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Storage
STORAGE_TYPE=local
STORAGE_BASE_PATH=/data

# MinIO (only when STORAGE_TYPE=minio)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=docrunr
MINIO_SECRET_KEY=docrunr-secret
MINIO_BUCKET=docrunr
MINIO_SECURE=false
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Worker (TXT extraction HTTP / bundled UI)
HEALTH_PORT=8080

# Host port published for worker-llm (container HTTP stays on 8080; map host 8081 → 8080)
LLM_HEALTH_PORT=8081
SQLITE_BASE_PATH=/db
JOB_TIMEOUT_SECONDS=120
WORKER_CONCURRENCY=1

# TXT extraction queues
RABBITMQ_QUEUE=docrunr.jobs
RABBITMQ_RESULT_QUEUE=docrunr.results
RABBITMQ_DLQ_QUEUE=docrunr.dlq

# LLM worker — LiteLLM proxy URL (worker-llm). In Docker Compose use the service hostname (set in docker-compose.llm.yml). For host-only dev (scripts/dev.mjs) use http://127.0.0.1:4000.
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=
LITELLM_TIMEOUT_SECONDS=120
RABBITMQ_LLM_QUEUE=docrunr.llm.jobs
RABBITMQ_LLM_RESULT_QUEUE=docrunr.llm.results
RABBITMQ_LLM_DLQ_QUEUE=docrunr.llm.dlq

# Ollama in Docker (docker-compose.ollama.yml): models pulled on container start (comma-separated).
# If OLLAMA_EMBED_MODELS is set, it wins; otherwise OLLAMA_EMBED_MODEL (single name). Names must match litellm.yaml / your jobs.
# OLLAMA_EMBED_MODELS=nomic-embed-text,llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Auth (optional)
UI_PASSWORD=

# Integration tests
DOCRUNR_INTEGRATION_STORAGE=local
DOCRUNR_INTEGRATION_MINIO_ENDPOINT=127.0.0.1:9000
DOCRUNR_INTEGRATION_MINIO_SECURE=false
