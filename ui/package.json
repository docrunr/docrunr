    "@tanstack/react-table": "8.21.3",
    "dompurify": "^3.3.3",
    "i18next": "^26.0.4",
    "marked": "^18.0.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.2",
    "recharts": "^3.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@eslint/js": "^9.0.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "fallow": "^2.13.0",
    "globals": "^16.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.3",
